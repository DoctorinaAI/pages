{
    "name": "pages",
    "version": "0.0.4",
    "description": "Doctorina Pages - Multiple lightweight HTML pages",
    "type": "module",
    "scripts": {
        "dev": "vite --open /index",
        "dev:index": "vite --open /pages/index/index.html",
        "dev:tools": "vite --open /pages/tools/index.html",
        "dev:ads": "vite --open /ads",
        "build": "vite build",
        "build:widget": "vite build --config vite.widget.config.ts",
        "build:all": "npm run build && npm run build:widget",
        "build:analyze": "ANALYZE=true vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "clean": "rimraf dist",
        "deps": "npm update && npm outdated",
        "deploy": "npm run build:all && firebase deploy --only hosting",
        "deploy:preview": "npm run build:all && firebase hosting:channel:deploy preview",
        "firebase:login": "firebase login",
        "firebase:init": "firebase init",
        "firebase:serve": "npm run build && firebase serve"
    },
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "25.5.0",
        "@vitest/ui": "^4.1.2",
        "eslint": "^10.1.0",
        "firebase-tools": "15.12.0",
        "jsdom": "^29.0.1",
        "rollup-plugin-visualizer": "7.0.1",
        "sharp": "0.34.5",
        "terser": "5.46.1",
        "typescript": "6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "8.0.3",
        "vitest": "^4.0.16"
    }
}